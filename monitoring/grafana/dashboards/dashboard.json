{
  "uid": "clip-search-overview",
  "title": "CLIP Search API",
  "tags": ["mlops", "clip"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },

  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Search API Up",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN",  "color": "red"   } } },
            { "type": "value", "options": { "1": { "text": "UP",    "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red"   },
              { "value": 1,    "color": "green" }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "up{job=\"search_api\"}",
          "legendFormat": "search_api",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Postgres Up",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red"   } } },
            { "type": "value", "options": { "1": { "text": "UP",   "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red"   },
              { "value": 1,    "color": "green" }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "up{job=\"postgres\"}",
          "legendFormat": "postgres",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Request Rate (req/s)",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 50,   "color": "yellow" },
              { "value": 100,  "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"search_api\"}[1m])",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "id": 4,
      "type": "stat",
      "title": "p95 Latency",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green"  },
              { "value": 1.0,  "color": "yellow" },
              { "value": 2.0,  "color": "red"    }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"search_api\"}[5m]))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "id": 5,
      "type": "stat",
      "title": "Error Rate",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green"  },
              { "value": 0.01, "color": "yellow" },
              { "value": 0.05, "color": "red"    }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"search_api\", status=~\"5..\"}[5m]) / rate(http_requests_total{job=\"search_api\"}[5m])",
          "legendFormat": "5xx rate",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "Request Rate by Endpoint",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"search_api\"}[1m])",
          "legendFormat": "{{handler}} {{method}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Latency Percentiles (p50 / p95 / p99)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"search_api\"}[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"search_api\"}[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"search_api\"}[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "HTTP Status Code Breakdown",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 7 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"search_api\"}[1m])",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "id": 9,
      "type": "timeseries",
      "title": "Postgres Active Connections",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 7 },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "pg_stat_activity_count{job=\"postgres\"}",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },

    {
      "id": 10,
      "type": "logs",
      "title": "Active Alerts",
      "gridPos": { "x": 0, "y": 19, "w": 24, "h": 5 },
      "options": { "showTime": true, "sortOrder": "Descending" },
      "targets": [
        {
          "expr": "ALERTS{alertstate=\"firing\"}",
          "legendFormat": "{{alertname}} — {{severity}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }

  ]
}